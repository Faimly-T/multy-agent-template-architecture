{
  "project": "Agent-WorkFlow-PO-PjM-Architect-V2",
  "description": "Multi-agent planning team for knowledge capture — CODE 5-Phase Execution Relay",
  "paths": {
    "outputs": "outputs",
    "marks": "outputs/contextAgent",
    "decisions": "outputs/decisions"
  },
  "agents": {
    "ux-persona": {
      "file": "agents/ux-persona/AGENT.md",
      "prefix": "UX",
      "output": "outputs/personas",
      "template": "agents/ux-persona/context/persona-card-template.md",
      "role": "agents/ux-persona/context/ROLE.md"
    },
    "ux-journey": {
      "file": "agents/ux-journey/AGENT.md",
      "prefix": "JRN",
      "output": "outputs/journeys",
      "template": "agents/ux-journey/context/journey-map-template.md",
      "role": "agents/ux-journey/context/ROLE.md"
    },
    "question-interviewer": {
      "file": "agents/question-interviewer/AGENT.md",
      "prefix": "PJM",
      "output": "outputs/meetings",
      "template": "agents/question-interviewer/context/question-interview-template.md",
      "role": "agents/question-interviewer/context/ROLE.md"
    },
    "product-owner": {
      "file": "agents/product-owner/AGENT.md",
      "prefix": "PO",
      "output": "outputs/plans",
      "template": null,
      "role": "agents/product-owner/context/ROLE.md"
    },
    "architect": {
      "file": "agents/architect/AGENT.md",
      "prefix": "ARCH",
      "output": "outputs/architecture",
      "template": null,
      "role": "agents/architect/context/ROLE.md"
    },
    "ux-orchestrator": {
      "file": "agents/ux-orchestrator/AGENT.md",
      "prefix": "UXORCH",
      "output": "outputs/status",
      "template": null,
      "role": "agents/ux-orchestrator/context/ROLE.md",
      "type": "orchestrator",
      "childAgents": ["ux-persona", "ux-journey", "question-interviewer"],
      "triggers": {
        "new-scope": "commands/{child}/new-scope.md",
        "iterate": "commands/{child}/iterate.md",
        "redesign": "commands/{child}/redesign.md",
        "collect": "commands/{child}/collect.md"
      }
    }
  },
  "skills": {
    "rehydrate-context": "skills/rehydrate-context/SKILL.md",
    "autonomous-capture": "skills/autonomous-capture/SKILL.md",
    "strategic-organize": "skills/strategic-organize/SKILL.md",
    "expert-distill": "skills/expert-distill/SKILL.md",
    "express-relay": "skills/express-relay/SKILL.md",
    "requirements-analysis": "skills/requirements-analysis/SKILL.md",
    "backlog-management": "skills/backlog-management/SKILL.md",
    "risk-assessment": "skills/risk-assessment/SKILL.md",
    "architecture-design": "skills/architecture-design/SKILL.md",
    "knowledge-capture": "skills/knowledge-capture/SKILL.md",
    "orch-clarify": "skills/orch-clarify/SKILL.md",
    "orch-state-track": "skills/orch-state-track/SKILL.md",
    "orch-response-cycle": "skills/orch-response-cycle/SKILL.md",
    "orch-termination": "skills/orch-termination/SKILL.md"
  },
  "chainOrder": ["ux-persona", "ux-journey"],
  "authority": {
    "personas": "ux-persona",
    "journeys": "ux-journey",
    "scope": "product-owner",
    "technical": "architect",
    "questions": "question-interviewer",
    "ux-research-workflow": "ux-orchestrator"
  }
}
